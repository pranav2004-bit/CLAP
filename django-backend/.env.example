# ============================================================
# CLAP Django Backend — Complete Environment Variables
# Copy this file to .env and fill in your actual values
# Lines starting with # are comments — safe to leave as-is
# ============================================================

# ── Django Core ──────────────────────────────────────────────
SECRET_KEY=your-secret-key-minimum-50-chars-change-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-backend-domain.com

# ── Database (Supabase PostgreSQL) ───────────────────────────
DB_NAME=postgres
DB_USER=postgres.your-project-ref
DB_PASSWORD=your_supabase_db_password
DB_HOST=aws-0-ap-southeast-1.pooler.supabase.com
DB_PORT=6543
DB_SSLMODE=require
DB_CONN_MAX_AGE=600
DB_CONNECT_TIMEOUT=10
DB_STATEMENT_TIMEOUT_MS=30000

# ── CORS (Frontend URL) ──────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend-domain.com

# ── Redis (Celery broker + rate limiting + cache) ────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Celery Task Limits ───────────────────────────────────────
CELERY_RESULT_EXPIRES=3600
CELERY_TASK_TIME_LIMIT=600
CELERY_TASK_SOFT_TIME_LIMIT=540

# ── LLM Provider ─────────────────────────────────────────────
# Options: openai | gemini
LLM_PROVIDER=openai

# OpenAI (required for Whisper audio transcription always)
OPENAI_API_KEY=sk-proj-your-openai-api-key-here
# Model options: gpt-4-turbo | gpt-4o | gpt-4o-mini
OPENAI_MODEL=gpt-4-turbo

# Gemini (only fill if LLM_PROVIDER=gemini)
# Note: OPENAI_API_KEY still required above for Whisper even when using Gemini
GEMINI_API_KEY=AIzaSy-your-gemini-api-key-here
# Model options: gemini-1.5-pro | gemini-1.5-flash
GEMINI_MODEL=gemini-1.5-pro

# ── Media Storage ─────────────────────────────────────────────
# Controls where audio recordings and PDF report cards are stored.
# Options:
#   aws      — Amazon S3
#   supabase — Supabase Storage (S3-compatible, no extra cost if already on Supabase)
#   (empty)  — Local disk only (development only, not for production)
STORAGE_PROVIDER=aws

# AWS S3 (fill these when STORAGE_PROVIDER=aws)
S3_BUCKET_NAME=clap-storage
S3_REGION_NAME=ap-south-1
S3_ACCESS_KEY_ID=AKIA-your-aws-access-key-id
S3_SECRET_ACCESS_KEY=your-aws-secret-access-key
S3_REPORT_PREFIX=reports
S3_PRESIGNED_URL_EXPIRY_SECONDS=604800

# Supabase Storage (fill these when STORAGE_PROVIDER=supabase)
# Get from: Supabase Dashboard → Storage → S3 Access
SUPABASE_PROJECT_REF=your-supabase-project-ref
SUPABASE_STORAGE_BUCKET=clap-storage
SUPABASE_STORAGE_ACCESS_KEY=your-supabase-storage-access-key
SUPABASE_STORAGE_SECRET_KEY=your-supabase-storage-secret-key
# Region of your Supabase project (ap-southeast-1, us-east-1, eu-west-1, etc.)
SUPABASE_STORAGE_REGION=ap-southeast-1

# ── Email Provider ────────────────────────────────────────────
# Options:
#   sendgrid — SendGrid SMTP (free: 100 emails/day)
#   ses      — Amazon SES SMTP (cheapest at scale)
#   console  — Dev only: prints emails to terminal, no real sending
EMAIL_PROVIDER=console
FROM_EMAIL=noreply@your-domain.com

# SendGrid (fill when EMAIL_PROVIDER=sendgrid)
# Also works for Resend — just change EMAIL_HOST to smtp.resend.com and EMAIL_HOST_USER to resend
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=SG.your-sendgrid-api-key-here

# AWS SES (fill when EMAIL_PROVIDER=ses)
AWS_SES_REGION=ap-south-1
AWS_SES_ACCESS_KEY_ID=AKIA-your-ses-smtp-username
AWS_SES_SECRET_ACCESS_KEY=your-ses-smtp-password

# Resend (alternative to SendGrid — use sendgrid provider setting + change SMTP host)
RESEND_API_KEY=re_your-resend-api-key-here

# ── Request Limits ────────────────────────────────────────────
DATA_UPLOAD_MAX_MEMORY_SIZE=10485760

# ── Rate Limits ───────────────────────────────────────────────
SUBMISSION_RATE_LIMIT_PER_USER_PER_HOUR=5
SUBMISSION_RATE_LIMIT_GLOBAL_PER_INSTITUTION_PER_HOUR=100
