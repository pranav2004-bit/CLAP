# ================================================================
# CLAP Django Backend — Complete Environment Configuration
# ================================================================
# HOW TO USE:
#   1. Copy this file → .env  (cp .env.example .env)
#   2. Fill in your actual values
#   3. For each service (LLM, Storage, Email) — uncomment the
#      block for the provider you want and leave others commented
#
# Lines starting with # are comments — safe to leave as-is
# ================================================================


# ── Django Core ─────────────────────────────────────────────────
# Generate a strong key: python -c "import secrets; print(secrets.token_urlsafe(60))"
SECRET_KEY=your-secret-key-minimum-50-chars-CHANGE-THIS-IN-PRODUCTION

# True for local dev (enables debug pages, disables TLS enforcement)
# NEVER set True in production
DEBUG=True

# Comma-separated. Add your production domain when deploying.
ALLOWED_HOSTS=localhost,127.0.0.1


# ── Database (Supabase PostgreSQL) ──────────────────────────────
# Get all values from: Supabase Dashboard → Project Settings → Database
#
# Use the "Session Mode" pooler connection string for Django
# (Transaction Mode / port 6543 doesn't support Django's CONN_MAX_AGE)
DB_NAME=postgres
DB_USER=postgres.your-project-ref               # e.g. postgres.abcdefghijkl
DB_PASSWORD=your_supabase_db_password
DB_HOST=aws-0-ap-south-1.pooler.supabase.com    # Your region's pooler host
DB_PORT=5432                                     # Session mode = 5432
DB_SSLMODE=require                               # Always require for Supabase

# Advanced — safe to leave as defaults
DB_CONN_MAX_AGE=600          # Connection pool lifetime in seconds
DB_CONNECT_TIMEOUT=10        # Timeout connecting to DB (seconds)
DB_STATEMENT_TIMEOUT_MS=30000 # Max query time before kill (milliseconds)


# ── CORS — Frontend URL(s) ───────────────────────────────────────
# Comma-separated list of origins allowed to call this backend
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-production-domain.com


# ── Redis ────────────────────────────────────────────────────────
# Required for: Celery task queue, rate limiting, idempotency cache
# Install Redis: https://redis.io/docs/getting-started/installation/
# Local dev default — all three can point to same Redis instance
REDIS_URL=redis://localhost:6379/2
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Production Redis (e.g. Redis Cloud, Upstash, AWS ElastiCache)
# REDIS_URL=rediss://:your-password@your-redis-host:6380/2
# CELERY_BROKER_URL=rediss://:your-password@your-redis-host:6380/0
# CELERY_RESULT_BACKEND=rediss://:your-password@your-redis-host:6380/1


# ── Celery Worker Settings ───────────────────────────────────────
CELERY_RESULT_EXPIRES=3600        # How long to keep task results (seconds)
CELERY_TASK_TIME_LIMIT=600        # Hard kill after 10 minutes
CELERY_TASK_SOFT_TIME_LIMIT=540   # Graceful stop after 9 minutes


# ── Rate Limiting ─────────────────────────────────────────────────
SUBMISSION_RATE_LIMIT_PER_USER_PER_HOUR=10
SUBMISSION_RATE_LIMIT_GLOBAL_PER_INSTITUTION_PER_HOUR=100

# API-level rate limiting (A5/E1) — requests per minute per IP / user_id
# Values below are conservative production defaults.  Raise RATE_LIMIT_AUTH_PER_MINUTE
# if legitimate users hit 429s (e.g., teachers loading large batch reports).
RATE_LIMIT_ENABLED=True
RATE_LIMIT_ANON_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=300


# ── Upload Limits ─────────────────────────────────────────────────
DATA_UPLOAD_MAX_MEMORY_SIZE=10485760   # 10 MB max upload size


# ── JWT Authentication ───────────────────────────────────────────
JWT_ACCESS_TOKEN_MINUTES=15     # Access token valid for 15 minutes
JWT_REFRESH_TOKEN_DAYS=7        # Refresh token valid for 7 days
JWT_ROTATE_REFRESH_TOKENS=True  # Issue new refresh token on every use
JWT_BLACKLIST_AFTER_ROTATION=True # Invalidate old refresh token after rotation


# ================================================================
# LLM PROVIDER
# ================================================================
# Set LLM_PROVIDER to either: openai  OR  gemini
#
# IMPORTANT: Even if you choose Gemini, OPENAI_API_KEY is still
# required because Whisper (OpenAI) is used for audio transcription.
# ================================================================

LLM_PROVIDER=openai

# ── Option A: OpenAI ─────────────────────────────────────────────
# Get key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model options (pick one):
#   gpt-4-turbo   → Best quality, higher cost
#   gpt-4o        → Faster, slightly lower cost
#   gpt-4o-mini   → Cheapest, good for testing
OPENAI_MODEL=gpt-4-turbo

# ── Option B: Google Gemini ───────────────────────────────────────
# Get key from: https://aistudio.google.com/app/apikey
# Activate by setting: LLM_PROVIDER=gemini
# NOTE: OPENAI_API_KEY above is still required for Whisper transcription
GEMINI_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model options (pick one):
#   gemini-1.5-pro    → Best quality
#   gemini-1.5-flash  → Faster, lower cost
GEMINI_MODEL=gemini-1.5-pro


# ================================================================
# STORAGE PROVIDER
# ================================================================
# Controls where audio recordings and PDF report cards are saved.
#
# Set STORAGE_PROVIDER to one of:
#   aws       → Amazon S3
#   supabase  → Supabase Storage (free if already on Supabase)
#   (empty)   → Local disk under django-backend/media/ (dev only)
# ================================================================

STORAGE_PROVIDER=supabase

# ── Option A: AWS S3 ─────────────────────────────────────────────
# Activate by setting: STORAGE_PROVIDER=aws
# Get credentials from: AWS Console → IAM → Users → Security credentials
S3_BUCKET_NAME=clap-storage
S3_REGION_NAME=ap-south-1
S3_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
S3_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
S3_ENDPOINT_URL=                          # Leave empty for standard AWS S3
S3_SIGNATURE_VERSION=s3v4
S3_ADDRESSING_STYLE=virtual

# ── Option B: Supabase Storage (S3-compatible) ───────────────────
# Activate by setting: STORAGE_PROVIDER=supabase
# Get from: Supabase Dashboard → Storage → S3 Access → Generate credentials
SUPABASE_PROJECT_REF=your-project-ref     # e.g. abcdefghijklmnop (16 chars)
SUPABASE_STORAGE_BUCKET=clap-storage      # Bucket name you create in Supabase Storage
SUPABASE_STORAGE_ACCESS_KEY=your-supabase-storage-access-key
SUPABASE_STORAGE_SECRET_KEY=your-supabase-storage-secret-key

# Region of your Supabase project — must match your project's region:
#   ap-south-1      → Asia Pacific (Mumbai)
#   ap-southeast-1  → Asia Pacific (Singapore)
#   us-east-1       → US East (N. Virginia)
#   eu-west-1       → Europe (Ireland)
SUPABASE_STORAGE_REGION=ap-south-1

# Shared storage settings (applies to both AWS and Supabase)
S3_REPORT_PREFIX=reports
# E5: Presigned URL lifetime for report links sent in emails.
# Default: 604800 = 7 days.  Consider reducing to 172800 (48 h) for higher
# security — shorter window if an email account is compromised.
# Configurable without code change via this env var.
S3_PRESIGNED_URL_EXPIRY_SECONDS=604800    # 7 days (link in email stays valid)


# ================================================================
# EMAIL PROVIDER
# ================================================================
# Set EMAIL_PROVIDER to one of:
#   sendgrid  → SendGrid SMTP (100 free emails/day)
#   ses       → Amazon SES (cheapest at scale, ~$0.10 per 1000)
#   resend    → Resend.com (3000 free emails/month)
#   console   → Dev only — prints email to terminal, nothing sent
# ================================================================

EMAIL_PROVIDER=console
FROM_EMAIL=noreply@your-verified-domain.com

# ── Option A: SendGrid ───────────────────────────────────────────
# Activate by setting: EMAIL_PROVIDER=sendgrid
# Get API key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# These are fixed for SendGrid — do not change:
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=   ← auto-filled from SENDGRID_API_KEY above

# ── Option B: Amazon SES ─────────────────────────────────────────
# Activate by setting: EMAIL_PROVIDER=ses
# Get from: AWS Console → SES → SMTP Settings → Create SMTP credentials
AWS_SES_REGION=ap-south-1
AWS_SES_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx     # SES SMTP username (different from S3 key!)
AWS_SES_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # SES SMTP password

# ── Option C: Resend ─────────────────────────────────────────────
# Activate by setting: EMAIL_PROVIDER=sendgrid (uses sendgrid config path)
# Then override these two lines:
#   EMAIL_HOST=smtp.resend.com
#   EMAIL_HOST_USER=resend
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Manual SMTP overrides (only needed if customising host/port beyond above)
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=    # Leave blank — auto-filled from SENDGRID_API_KEY


# ================================================================
# SECURITY (Production Only)
# ================================================================
# These are auto-configured based on DEBUG value.
# Only set manually if you need to override defaults.
# ================================================================

# ENFORCE_TLS=True                      # Auto True when DEBUG=False
# SECURE_HSTS_SECONDS=31536000          # 1 year HSTS
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=                  # Defaults to ENFORCE_TLS value. Set True
#                                       # only after testing — HSTS preload is
#                                       # irreversible for ~1 year once submitted.
# SECURE_REFERRER_POLICY=strict-origin-when-cross-origin

# E2: x-user-id header trust (Supabase JWT fallback)
# Set to False in production when NOT behind a trusted reverse proxy that strips
# arbitrary x-user-id headers from untrusted clients.
TRUST_X_USER_ID_HEADER=True


# ================================================================
# AWS SECRETS MANAGER (Optional — Advanced)
# ================================================================
# Leave as 'env' to read secrets from this file (default).
# Set to 'aws' to read OPENAI_API_KEY, SENDGRID_API_KEY etc.
# from AWS Secrets Manager instead of this file.
# ================================================================

SECRETS_MANAGER_PROVIDER=env
# SECRETS_MANAGER_PROVIDER=aws
# SECRETS_MANAGER_REGION=ap-south-1
# SECRETS_MANAGER_PREFIX=clap/


# ================================================================
# ERROR TRACKING (D4/E5)
# ================================================================
# sentry-sdk is already installed — just provide a DSN to activate.
# Get your DSN from: https://sentry.io → Project → Settings → Client Keys
# Leave blank to disable (safe default for development).
# ================================================================

SENTRY_DSN=
# SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxx@o000000.ingest.sentry.io/0000000

# Performance tracing: fraction of requests traced (0.0 – 1.0).
# Start low (0.05 = 5%) and increase as you understand your traffic volume.
SENTRY_TRACES_SAMPLE_RATE=0.05


# ================================================================
# APPLICATION VERSION
# ================================================================
# Set to the current release tag (e.g. v1.4.2) so that:
#   - GET /api/health/  includes version in JSON response
#   - Sentry events are tagged with the release for easy regression tracking
#   - Docker images can be tagged: docker build --build-arg APP_VERSION=v1.4.2
# In CI, set this automatically: APP_VERSION=$(git describe --tags --always)
# ================================================================

APP_VERSION=


# ================================================================
# CDN DELIVERY (Phase 2 — optional)
# ================================================================
# When CDN_ENABLED=False (default), all S3 URLs are returned unchanged.
# To activate CDN delivery:
#   1. Set CDN_ENABLED=True
#   2. Set CDN_BASE_URL to your CDN distribution domain
#   3. Ensure your CDN is configured to pull from the S3 bucket as origin
#
# CDN_PROVIDER is informational — used for Phase 2.3 signed URL generation.
# Supported values: 'cloudfront' | 'cloudflare' | 'fastly' | 'generic'
#
# CDN_SIGNED_URLS_ENABLED requires Phase 2.3 implementation (not yet built).
# Leave False until Phase 2.3 is complete.
# ================================================================

CDN_ENABLED=False
CDN_BASE_URL=
# CDN_BASE_URL=https://cdn.example.com
# CDN_BASE_URL=https://xxxxxxxxxxxx.cloudfront.net

CDN_PROVIDER=generic
CDN_SIGNED_URLS_ENABLED=False
