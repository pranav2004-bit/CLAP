{
  "title": "CLAP Pipeline Overview",
  "uid": "clap-pipeline-overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "tags": ["clap", "pipeline"],
  "panels": [
    {
      "type": "timeseries",
      "title": "Submission Throughput",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (status) (rate(clap_submissions_total[5m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Celery Queue Depth",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "clap_celery_queue_depth",
          "legendFormat": "{{queue_name}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "End-to-End Latency p95",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(clap_report_generation_duration_bucket[5m])))",
          "legendFormat": "report_generation_p95"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Unresolved DLQ Count",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "clap_dlq_unresolved_count",
          "legendFormat": "{{task_type}}"
        }
      ]
    }
  ]
}
