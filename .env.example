# ================================================================
# CLAP Next.js Frontend — Complete Environment Configuration
# ================================================================
# HOW TO USE:
#   1. Copy this file → .env.local  (cp .env.example .env.local)
#   2. Fill in your actual values
#   3. Variables prefixed NEXT_PUBLIC_ are exposed to the browser
#      — never put secrets in NEXT_PUBLIC_ variables
# ================================================================


# ── Supabase (Database + Auth) ───────────────────────────────────
# Get both values from: Supabase Dashboard → Project Settings → API
#
# Project URL (public — safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon/public key (public — safe to expose, has row-level security)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here

# Service role key (PRIVATE — server-side only, never expose to browser)
# Only needed for admin scripts / server-side DB access
# Get from: Supabase Dashboard → Project Settings → API → service_role key
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key


# ── Django Backend API URL ────────────────────────────────────────
# Where the Next.js frontend sends API requests
# Local development:
NEXT_PUBLIC_API_URL=http://localhost:8000/api
# Production:
# NEXT_PUBLIC_API_URL=https://your-backend-domain.com/api


# ── Application Info ─────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=CLAP
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production:
# NEXT_PUBLIC_APP_URL=https://your-frontend-domain.com


# ── OpenAI (Client-side — only if using OpenAI directly in frontend) ──
# If all LLM calls go through Django backend, this is NOT needed here.
# Only set this if the frontend calls OpenAI directly.
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ── Email Service (Client-side sending — if used in Next.js API routes) ──
# These are only needed if the Next.js app sends emails directly.
# If all email goes through Django backend, leave these blank.

# Resend
# Get key from: https://resend.com/api-keys
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SendGrid
# Get key from: https://app.sendgrid.com/settings/api_keys
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ── Node Environment ─────────────────────────────────────────────
NODE_ENV=development
# NODE_ENV=production
