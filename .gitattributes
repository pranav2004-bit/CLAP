# Force LF line endings for files that run on Linux servers.
# Prevents Windows CRLF from breaking shell scripts deployed to EC2.

# Shell scripts — always LF (CRLF breaks /bin/sh on Linux)
*.sh        text eol=lf

# Python — always LF
*.py        text eol=lf

# Docker — always LF
Dockerfile  text eol=lf
*.dockerfile text eol=lf

# Nginx config — always LF
*.conf      text eol=lf

# YAML/JSON/env — always LF
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.env       text eol=lf
*.env.*     text eol=lf

# Windows-only files — always CRLF
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf
